# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Database (Cloudflare D1)
DATABASE_URL=your_d1_database_url

# Environment
ENVIRONMENT=development

# ─── POS Module ────────────────────────────────────────────────────────────────

# Paystack (Nigeria-First payment gateway)
# Get from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Thermal Receipt Printer
# Serial baud rate for ESC/POS thermal printers (common: 9600, 19200, 38400, 115200)
PRINT_THERMAL_BAUD_RATE=9600
# Thermal paper width: 58mm or 80mm (affects CSS @media print)
PRINT_THERMAL_WIDTH_MM=80
# Printer interface: serial | usb | network | browser (browser = window.print())
PRINT_INTERFACE=browser

# POS Session
# Maximum cashier session duration in hours (shift length)
POS_SESSION_MAX_HOURS=12
# Rate limit: max checkout calls per session per minute (PCI hardening)
POS_RATE_LIMIT_PER_MIN=10

# ─── Offline Sync ──────────────────────────────────────────────────────────────

# Maximum pending mutations before forcing sync
SYNC_MAX_PENDING=50
# Background sync retry interval in seconds
SYNC_RETRY_INTERVAL_SECONDS=30

# ─── Scanner / Barcode ─────────────────────────────────────────────────────────

# Scanner HID input device path (Linux: /dev/input/eventX, macOS: auto-detected)
SCANNER_DEVICE_PATH=/dev/input/event0
# Barcode scan terminator character (default: Enter = \n)
SCANNER_TERMINATOR=\n

# ─── Multi-tenancy ─────────────────────────────────────────────────────────────

# Default demo tenant for local development
SEED_TENANT_ID=tnt_demo
# Set to 1 to clear existing products before seeding
SEED_CLEAR=0

# ─── NDPR / Compliance (Nigeria Data Protection Regulation) ───────────────────

# Data retention period in days (NDPR minimum: 180 days)
NDPR_RETENTION_DAYS=180
# Consent version string (bump when privacy policy changes)
NDPR_CONSENT_VERSION=1.0

# ─── External Services ─────────────────────────────────────────────────────────

# Flutterwave (alternative Nigerian payment gateway)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx

# Termii (Nigerian SMS/OTP provider)
TERMII_API_KEY=your_termii_api_key

# WhatsApp Business API (for receipt sharing)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
