{
  "name": "webwaka-commerce",
  "version": "4.0.0",
  "description": "WebWaka Commerce Platform (POS, Storefront, Marketplace). Part of WebWaka OS v4.",
  "main": "index.js",
  "directories": { "doc": "docs" },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && echo 'TypeCheck passed'",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "preview:ui": "vite preview",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:ui": "wrangler pages deploy dist --project-name webwaka-commerce-ui --branch main",
    "deploy:ui:staging": "wrangler pages deploy dist --project-name webwaka-commerce-ui --branch develop",
    "migrate:staging": "bash scripts/migrate.sh staging",
    "migrate:prod": "bash scripts/migrate.sh production",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260331.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "dexie": "^4.4.2",
    "hono": "^4.12.9",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "@webwaka/core": "^1.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wrangler": "^4.79.0"
  }
}